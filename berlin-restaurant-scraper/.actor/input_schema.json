{
  "title": "Berlin Restaurant Scraper Input",
  "type": "object",
  "schemaVersion": 1,
  "properties": {
    "mode": {
      "title": "Result set",
      "type": "string",
      "description": "Which result set to return.",
      "editor": "select",
      "enum": ["withReviews", "limited", "minimal"],
      "enumTitles": ["With reviews", "Limited", "Minimal"],
      "default": "withReviews"
    },
    "count": {
      "title": "Item count",
      "type": "integer",
      "description": "How many listings to return (1-50).",
      "default": 3,
      "minimum": 1,
      "maximum": 50
    },
    "delayMs": {
      "title": "Per-item delay (ms)",
      "type": "integer",
      "description": "Delay between returned listings, in milliseconds.",
      "default": 150,
      "minimum": 0
    }
  }
}
