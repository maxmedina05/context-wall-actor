# Copy to .env and fill in. .env is gitignored.

# REQUIRED for the real Apify client (local runs).
# main.ts uses Actor.getEnv().token first (set automatically on the Apify
# platform) and falls back to APIFY_TOKEN locally.
# Get it: Apify Console -> Settings -> API & Integrations.
APIFY_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OPTIONAL. Tier 2 semantic judge (Gemini). Omit -> keyword heuristic fallback.
# Get it: Google AI Studio -> API keys.
GEMINI_API_KEY=

# OPTIONAL. Override the Gemini model (default below).
GEMINI_MODEL=gemini-2.5-flash-lite
